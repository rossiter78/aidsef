# AIDSEF environment — copy to .env and fill in. .env is gitignored;
# never commit real hostnames, tokens, or keys (see CLAUDE.md Phase A
# ground rules). GitHub Actions read CLAUDE_CODE_OAUTH_TOKEN from the
# repository's Actions secrets, not from this file.

# --- Local model plane (Phase B) -------------------------------------------
# The vLLM server on your inference host (the DGX Spark), OpenAI-compatible.
AIDSEF_VLLM_BASE=http://YOUR-INFERENCE-HOST:8000/v1

# The LiteLLM gateway that fronts the local models (on your Docker server).
# Local-role agents point ANTHROPIC_BASE_URL at this.
AIDSEF_LITELLM_URL=http://YOUR-DOCKER-HOST:4000

# Which network interface the gateway listens on, set on the Docker server.
# Use that host's Tailscale address so only the private mesh can reach it.
# Leave unset for loopback-only (safe, but your laptop cannot reach it).
# NEVER 0.0.0.0: that publishes the gateway on every interface, leaving only
# the master key between the internet and your models.
LITELLM_BIND_ADDR=100.x.y.z

# LiteLLM admin master key (generate a random one; keep it secret).
# e.g. openssl rand -hex 24
LITELLM_MASTER_KEY=sk-REPLACE-ME

# --- Autonomy --------------------------------------------------------------
# Level 2 (resident runner) activates only when this is '2' AND a
# hardened self-hosted runner exists. Changing it requires a
# human-approved constitution amendment (constitution §6).
AIDSEF_AUTONOMY_LEVEL=0
